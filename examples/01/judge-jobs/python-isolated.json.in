{
  "request_id": "examples-01-python-judge",
  "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python",
  "compile": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python/compile",
    "config": {
      "process": {
        "argv": [
          "/bin/sh",
          "-c",
          "cp /inputs/solution.py /output/solution.py && /usr/bin/python3 -m py_compile /output/solution.py"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 5000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "output_dir": "/output",
        "readonly_bind_paths": [
          "__REPO_ROOT__/examples/01/languages/python/solution.py"
        ],
        "executable_bind_paths": [
          "/bin",
          "/usr/bin"
        ]
      }
    }
  },
  "run": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python/run",
    "inputs": {
      "readonly_artifacts": [
        {
          "stage": "compile",
          "artifact_path": "outputs/solution.py"
        }
      ]
    },
    "config": {
      "process": {
        "argv": [
          "/usr/bin/python3",
          "/inputs/compile/outputs/solution.py"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "executable_bind_paths": [
          "/bin",
          "/usr/bin"
        ]
      }
    }
  },
  "checker": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python/checker",
    "inputs": {
      "stdin": {
        "stage": "run",
        "artifact_path": "stdout.log"
      }
    },
    "config": {
      "process": {
        "argv": [
          "/bin/grep",
          "^sum=7$"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "executable_bind_paths": [
          "/bin",
          "/usr/bin"
        ]
      }
    }
  }
}
