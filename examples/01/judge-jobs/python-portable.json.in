{
  "request_id": "examples-01-python-judge-portable",
  "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable",
  "compile": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile",
    "config": {
      "process": {
        "argv": [
          "/bin/sh",
          "-c",
          "mkdir -p __REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile/outputs && cp __REPO_ROOT__/examples/01/languages/python/solution.py __REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile/outputs/solution.py && /usr/bin/python3 -m py_compile __REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile/outputs/solution.py"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 5000
      },
      "filesystem": {
        "enable_rootfs": false,
        "output_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile/outputs"
      }
    }
  },
  "run": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/run",
    "config": {
      "process": {
        "argv": [
          "/usr/bin/python3",
          "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/compile/outputs/solution.py"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": false
      }
    }
  },
  "checker": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-python-portable/checker",
    "inputs": {
      "stdin": {
        "stage": "run",
        "artifact_path": "stdout.log"
      }
    },
    "config": {
      "process": {
        "argv": [
          "/bin/grep",
          "^sum=7$"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": false
      }
    }
  }
}
