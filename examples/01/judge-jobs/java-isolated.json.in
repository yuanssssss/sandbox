{
  "request_id": "examples-01-java-judge",
  "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-java",
  "compile": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-java/compile",
    "config": {
      "process": {
        "argv": [
          "/usr/bin/javac",
          "-d",
          "/output",
          "/inputs/Main.java"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 8000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "output_dir": "/output",
        "readonly_bind_paths": [
          "__REPO_ROOT__/examples/01/languages/java/Main.java"
        ],
        "executable_bind_paths": [
          "/bin",
          "/usr/bin",
          "/etc/alternatives"
        ]
      }
    }
  },
  "run": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-java/run",
    "inputs": {
      "readonly_artifacts": [
        {
          "stage": "compile",
          "artifact_path": "outputs/Main.class"
        }
      ]
    },
    "config": {
      "process": {
        "argv": [
          "/usr/bin/java",
          "-cp",
          "/inputs/compile/outputs",
          "Main"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 2000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "executable_bind_paths": [
          "/bin",
          "/usr/bin",
          "/etc/alternatives"
        ]
      }
    }
  },
  "checker": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-java/checker",
    "inputs": {
      "stdin": {
        "stage": "run",
        "artifact_path": "stdout.log"
      }
    },
    "config": {
      "process": {
        "argv": [
          "/bin/grep",
          "^sum=7$"
        ],
        "cwd": "/work",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": true,
        "enter_user_namespace": true,
        "enter_mount_namespace": true,
        "enter_pid_namespace": true,
        "apply_mounts": true,
        "chroot_to_rootfs": true,
        "work_dir": "/work",
        "tmp_dir": "/tmp",
        "executable_bind_paths": [
          "/bin",
          "/usr/bin",
          "/etc/alternatives"
        ]
      }
    }
  }
}
