{
  "request_id": "examples-01-cpp-judge-portable",
  "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable",
  "compile": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/compile",
    "config": {
      "process": {
        "argv": [
          "/usr/bin/c++",
          "-std=c++17",
          "-O2",
          "__REPO_ROOT__/examples/01/languages/cpp/main.cpp",
          "-o",
          "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/compile/outputs/main"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 5000
      },
      "filesystem": {
        "enable_rootfs": false,
        "output_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/compile/outputs"
      }
    }
  },
  "run": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/run",
    "config": {
      "process": {
        "argv": [
          "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/compile/outputs/main"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": false
      }
    }
  },
  "checker": {
    "artifact_dir": "__REPO_ROOT__/.sandbox-runs/examples-01/judge-cpp-portable/checker",
    "inputs": {
      "stdin": {
        "stage": "run",
        "artifact_path": "stdout.log"
      }
    },
    "config": {
      "process": {
        "argv": [
          "/bin/grep",
          "^sum=7$"
        ],
        "cwd": "__REPO_ROOT__",
        "env": [
          "LANG=C",
          "PATH=/usr/bin:/bin"
        ],
        "clear_env": true
      },
      "limits": {
        "wall_time_ms": 1000
      },
      "filesystem": {
        "enable_rootfs": false
      }
    }
  }
}
