# Docker / Compose defaults
COMPOSE_PROJECT_NAME=sandbox

# Published HTTP port on the host
SANDBOX_PORT=3000

# Image / container names
SANDBOX_PROD_IMAGE=sandbox-prod
SANDBOX_PROD_CONTAINER=sandbox-prod
SANDBOX_DEV_IMAGE=sandbox-dev
SANDBOX_DEV_CONTAINER=sandbox-dev

# Protocol server limits
SANDBOX_MAX_REQUEST_BODY_BYTES=1048576
SANDBOX_MAX_CONCURRENT_REQUESTS=32

# Optional bearer token for API requests.
# Leave empty to disable auth in local development.
SANDBOX_PROTOCOL_AUTH_TOKEN=
